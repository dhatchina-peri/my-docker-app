pipeline {
    agent any

    stages {
        stage('Clone Code') {
            steps {
                git 'https://github.com/dhatchina-peri/my-docker-app.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                sh 'docker build -t my-nginx-app .'
            }
        }

        stage('Stop Old Container') {
            steps {
                sh 'docker rm -f my-container || true'
            }
        }

        stage('Run Container') {
            steps {
                sh 'docker run -d -p 80:80 --name my-container my-nginx-app'
            }
        }
    }
}

